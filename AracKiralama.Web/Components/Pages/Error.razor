@page "/Error"
@attribute [AllowAnonymous]
@using System.Diagnostics

<PageTitle>Hata</PageTitle>

<div class="mx-auto" style="max-width: 640px;">
<h1 class="text-danger h3 fw-bold">Hata</h1>
<h2 class="text-danger h5 fw-normal">İsteğiniz işlenirken bir sorun oluştu.</h2>

@if (ShowRequestId)
{
    <p class="mt-3">
        <strong>İstek kimliği:</strong> <code>@RequestId</code>
    </p>
}

<h3 class="h6 fw-bold mt-4">Geliştirme ortamı</h3>
<p class="text-muted">
    <strong>Development</strong> ortamına geçildiğinde, oluşan hata hakkında daha ayrıntılı bilgi gösterilir.
</p>
<p class="text-muted">
    <strong>Canlı ortamda Development modunu açmayın.</strong>
    İstisna ayrıntıları son kullanıcıya sızdırılabilir.
</p>
<p class="text-muted">
    Yerel hata ayıklama için <strong>ASPNETCORE_ENVIRONMENT</strong> ortam değişkenini <strong>Development</strong> yapıp uygulamayı yeniden başlatın.
</p>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
