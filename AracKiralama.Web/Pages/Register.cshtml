@page "/Register"
@model AracKiralama.Web.Pages.RegisterModel
@{
    ViewData["Title"] = "Kayıt";
}

<div class="auth-card">
    <p class="text-muted small mb-1">Araç Kiralama</p>
    <h2 class="mb-1">Müşteri kaydı</h2>
    <p class="text-muted small mb-4">Rezervasyon için hesap oluşturun</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }
    <form method="post">
        <div class="mb-3">
            <label class="form-label" asp-for="Input.FullName"></label>
            <input class="form-control" asp-for="Input.FullName" />
            <span class="text-danger small" asp-validation-for="Input.FullName"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.Email"></label>
            <input class="form-control" asp-for="Input.Email" autocomplete="email" />
            <span class="text-danger small" asp-validation-for="Input.Email"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.Phone"></label>
            <input class="form-control" asp-for="Input.Phone" />
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.IsCorporate"></label>
            <select class="form-select" asp-for="Input.IsCorporate">
                <option value="false">Bireysel</option>
                <option value="true">Kurumsal</option>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.TaxNumber"></label>
            <input class="form-control" asp-for="Input.TaxNumber" placeholder="Yalnızca kurumsal müşteriler için" />
            <span class="text-danger small" asp-validation-for="Input.TaxNumber"></span>
        </div>
        <div class="mb-3">
            <label class="form-label" asp-for="Input.Password"></label>
            <input class="form-control" asp-for="Input.Password" autocomplete="new-password" />
            <span class="text-danger small" asp-validation-for="Input.Password"></span>
        </div>
        <div class="mb-4">
            <label class="form-label" asp-for="Input.ConfirmPassword"></label>
            <input class="form-control" asp-for="Input.ConfirmPassword" autocomplete="new-password" />
            <span class="text-danger small" asp-validation-for="Input.ConfirmPassword"></span>
        </div>
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary btn-lg">Kayıt ol</button>
        </div>
        <div class="text-center mt-3">
            <a class="btn btn-link" href="/Login">Girişe dön</a>
        </div>
    </form>
</div>
